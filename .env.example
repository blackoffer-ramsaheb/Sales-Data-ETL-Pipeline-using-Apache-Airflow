# ── Airflow Core ─────────────────────────────────────────────────────────────
AIRFLOW_UID=50000
AIRFLOW_IMAGE_NAME=apache/airflow:3.2.2

# ── Admin credentials ────────────────────────────────────────────────────────
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# ── Security keys ────────────────────────────────────────────────────────────
# Generate a Fernet key:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your_fernet_key_here

# JWT for the Airflow API server
AIRFLOW__API_AUTH__JWT_SECRET=airflow_jwt_secret_change_me
AIRFLOW__API_AUTH__JWT_ISSUER=airflow

# ── Project directory ─────────────────────────────────────────────────────────
# AIRFLOW_PROJ_DIR=.

# ── Python path ───────────────────────────────────────────────────────────────
PYTHONPATH=/opt/airflow/scripts:/opt/airflow

# ── Additional pip packages installed at container startup ───────────────────
# (For production, build a custom Docker image instead)
_PIP_ADDITIONAL_REQUIREMENTS=psycopg2-binary>=2.9

# ── Sales ETL — dedicated PostgreSQL database ─────────────────────────────────
# Connect from your Windows machine:
#   Host: localhost  |  Port: 5433  |  DB: sales_db  |  User: sales_user
SALES_DB_NAME=sales_db
SALES_DB_USER=sales_user
SALES_DB_PASSWORD=sales_password
