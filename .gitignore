# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
*.whl
.eggs/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Airflow ───────────────────────────────────────────────────────────────────
logs/
