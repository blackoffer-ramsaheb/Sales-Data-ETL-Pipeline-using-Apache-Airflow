!logs/.gitkeep

# ── SQLite database ───────────────────────────────────────────────────────────
database/sales.db

# ── Generated / processed data (keep raw source data) ────────────────────────
data/processed/
data/reports/

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
# Track the example env file instead
!.env.example

# ── Docker ────────────────────────────────────────────────────────────────────
.docker/

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.code-workspace

# ── Airflow config (auto-generated by the container) ─────────────────────────
config/airflow.cfg
config/webserver_config.py
